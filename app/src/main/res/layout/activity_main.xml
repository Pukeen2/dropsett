<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="?attr/colorSurface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnStartWorkout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Workout"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/ds_primary"
        android:textColor="@color/ds_on_primary"/>

    <Button
        android:id="@+id/btnExercises"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Exercises"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/ds_primary"
        android:textColor="@color/ds_on_primary"/>

    <Button
        android:id="@+id/btnPlans"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Workout Plans"
        android:backgroundTint="@color/ds_primary"
        android:textColor="@color/ds_on_primary"/>
    <Button
        android:id="@+id/btnHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Workout History"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/ds_primary"
        android:textColor="@color/ds_on_primary"/>
</LinearLayout>