<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/hint_long_press_delete"
        android:textSize="12sp"
        android:textColor="@color/ds_secondary"
        android:gravity="center"
        android:paddingVertical="6dp"
        android:background="?attr/colorSurface"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPlans"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/tvEmptyPlans"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="No workout plans yet.\nTap + to create one."
        android:textColor="@color/ds_secondary"
        android:textSize="16sp"
        android:visibility="gone"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddPlan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/ds_primary"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>