<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="4dp">

    <TextView
        android:id="@+id/tvHistorySetNumber"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/ds_secondary"
        android:gravity="center"/>

    <TextView
        android:id="@+id/tvHistoryWeight"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"/>

    <TextView
        android:id="@+id/tvHistoryReps"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"/>

    <!-- RPE shown when not to failure -->
    <TextView
        android:id="@+id/tvHistoryRpe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="13sp"
        android:textColor="@color/ds_secondary"
        android:gravity="center"
        android:visibility="visible"/>

    <!-- FAIL shown when to failure, replaces RPE slot -->
    <TextView
        android:id="@+id/tvHistoryFailure"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/ds_error"
        android:gravity="center"
        android:visibility="gone"/>

</LinearLayout>