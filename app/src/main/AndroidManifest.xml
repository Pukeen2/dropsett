<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.VIBRATE"/>
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DropSett">
        <activity android:name=".ui.ExerciseListActivity"/>
        <activity android:name=".ui.PlanListActivity"/>
        <activity android:name=".ui.PlanBuilderActivity"/>
        <activity android:name=".ui.PlanDetailActivity"/>
        <activity android:name=".ui.WorkoutActivity"/>
        <activity android:name=".ui.HistoryActivity"/>
        <activity android:name=".ui.PlanPickerActivity"/>
        <activity android:name=".ui.SessionDetailActivity"/>
        <activity android:name=".ui.ExerciseHistoryActivity"/>
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>